{#-
  Prometheus HTTP SD export template — Device OOB (iDRAC/iLO/BMC).
  Bind to: dcim.device

  Emits one scrape target per active device whose config context carries a
  `prometheus-export-template-oob` block and which has an oob_ip. The scrape
  target is the device's OOB IP (or the exporter address when exporter routing
  is in use — the common case for iDRAC/iLO via idrac_exporter). `port` is
  optional — when omitted the target carries no `:port` suffix and Prometheus
  falls back to the scheme's default port.

  Primary / software monitoring is a SEPARATE template — device-prometheus-sd.j2,
  driven by the `prometheus-export-template` context key. The two are fully
  independent: a device can appear in neither, one, or both SD outputs.

  The OOB context is SELF-CONTAINED: prometheus_exporter_* custom-field overrides
  do NOT apply here (they target the primary emission). The only custom field read
  is monitoring_disable_alerts, which is a shared info label (identical on the
  primary and OOB rows for the same device).
-#}

{%- macro jstr(s) -%}
{{ s|string|replace('\\', '\\\\')|replace('"', '\\"')|replace('\n', '\\n')|replace('\r', '\\r')|replace('\t', '\\t') }}
{%- endmacro -%}

{%- macro build_labels(fields) -%}
  {%- set lbl = namespace(parts=[]) -%}
  {%- for name, value in fields -%}
    {%- if value -%}
      {%- set lbl.parts = lbl.parts + ['"' ~ name ~ '": "' ~ jstr(value)|trim ~ '"'] -%}
    {%- endif -%}
  {%- endfor -%}
  { {{ lbl.parts | join(', ') }} }
{%- endmacro -%}

{%- macro target_addr(ip, port) -%}
  {%- if ip.version == 6 -%}
    {%- if port -%}[{{ ip }}]:{{ port }}{%- else -%}[{{ ip }}]{%- endif -%}
  {%- else -%}
    {%- if port -%}{{ ip }}:{{ port }}{%- else -%}{{ ip }}{%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{%- macro param_value(v) -%}
{%- if v is none or v == '' -%}
{%- elif v is string -%}
{{ v }}
{%- elif v is iterable -%}
{{ v | select | map('string') | join(',') }}
{%- else -%}
{{ v }}
{%- endif -%}
{%- endmacro -%}

{%- set ns = namespace(rows=[]) -%}
{%- for target in queryset -%}
  {%- set cfg = target.get_config_context().get('prometheus-export-template-oob') -%}
  {%- if target.status and cfg and target.oob_ip -%}

    {%- set info_fields = [
      ('target_name', target.name),
      ('site', target.site.name if target.site else None),
      ('dc', target.site.slug if target.site else None),
      ('cluster', target.cluster.name if target.cluster else None),
      ('tenant', target.tenant.name if target.tenant else None),
      ('device_role', target.role.name if target.role else None),
      ('platform', target.platform.name if target.platform else None),
      ('manufacturer', target.device_type.manufacturer.name if target.device_type and target.device_type.manufacturer else None),
      ('device_type', target.device_type.model if target.device_type else None),
      ('location', target.location.name if target.location else None),
      ('rack', target.rack.name if target.rack else None),
      ('description', target.description if target.description else None),
      ('disable_alerts', 'true' if target.cf.get('monitoring_disable_alerts') else None),
    ] -%}

    {%- set device_addr = target_addr(target.oob_ip.address.ip, cfg.get('port'))|trim -%}

    {#- Scheme: with exporter routing, scheme prefixes __param_target so the exporter
        knows what protocol to probe. With no exporter, scheme is emitted as the
        Prometheus meta-label __scheme__. -#}
    {%- set scheme = cfg.get('scheme') -%}
    {%- if cfg.get('exporter') -%}
      {%- set scrape_target = cfg.exporter -%}
      {%- set param_target = (scheme ~ '://' ~ device_addr) if scheme else device_addr -%}
      {#- instance is the probed address WITHOUT the scheme prefix (host:port) — the
          scheme isn't part of the target's identity. __param_target keeps the scheme
          because the exporter needs to know what protocol to probe. -#}
      {%- set instance_label = device_addr -%}
      {%- set scheme_label = None -%}
    {%- else -%}
      {%- set scrape_target = device_addr -%}
      {%- set param_target = None -%}
      {%- set instance_label = None -%}
      {%- set scheme_label = scheme -%}
    {%- endif -%}

    {#- Params: context values only (no custom-field overrides on OOB). -#}
    {%- set params_ns = namespace(parts=[]) -%}
    {%- for k, v in (cfg.get('params') or {}).items() -%}
      {%- set params_ns.parts = params_ns.parts + [('__param_' ~ k, param_value(v)|trim)] -%}
    {%- endfor -%}

    {#- With exporter routing __address__ is the exporter, so Prometheus' default
        instance (=__address__) would collide across every target behind that
        exporter. Emit instance = the probed OOB address (host:port, no scheme);
        instance_label is set only when an exporter is in use, build_labels drops
        it otherwise. -#}
    {%- set fields = [
      ('__param_target', param_target),
      ('instance', instance_label),
      ('__metrics_path__', cfg.get('metrics_path')),
      ('__scheme__', scheme_label),
      ('__scrape_interval__', cfg.get('scrape_interval')),
      ('__scrape_timeout__', cfg.get('scrape_timeout')),
      ('exporter_type', cfg.get('exporter_type')),
    ] + params_ns.parts + info_fields -%}
    {%- set ns.rows = ns.rows + [(scrape_target, fields)] -%}
  {%- endif -%}
{%- endfor -%}
[
{%- for scrape_target, fields in ns.rows %}
    {
        "targets": ["{{ scrape_target }}"],
        "labels": {{ build_labels(fields) }}
    }{% if not loop.last %},{% endif %}
{%- endfor %}
]
