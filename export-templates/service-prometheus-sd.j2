{#-
  Prometheus HTTP SD export template — Services (direct scrape).
  Bind to: ipam.service

  Emits one direct-scrape target per (service, port) pair for every active
  service whose parent device/VM has a primary IP. The scrape target is
  `<parent primary IP>:<port>`; Prometheus' job-level scheme and metrics_path
  apply (no per-target override) unless the custom field below is set.

  Per-service override — custom field `prometheus_scrape_url` on ipam.service:
  when set, its value is fed verbatim into the target (`__address__`) and the
  service's `ports` field is ignored (exactly one row is emitted). The template
  does not parse it — whatever you put in the CF is what Prometheus receives as
  the target, so make it whatever your scrape job expects (`host:port`, or a
  full URL if your relabel config decomposes it).

  This template does NOT do exporter routing (snmp_exporter, fortigate_exporter,
  etc.) where many services ride a single shared exporter address via
  __param_target. Handle that in the Prometheus scrape job's relabel_configs
  (move __address__ to __param_target, rewrite __address__ to the exporter) —
  same pattern as the blackbox jobs. See prometheus/scrape-configs.yml.
-#}

{%- macro jstr(s) -%}
{{ s|string|replace('\\', '\\\\')|replace('"', '\\"')|replace('\n', '\\n')|replace('\r', '\\r')|replace('\t', '\\t') }}
{%- endmacro -%}

{%- macro build_labels(fields) -%}
  {%- set lbl = namespace(parts=[]) -%}
  {%- for name, value in fields -%}
    {%- if value -%}
      {%- set lbl.parts = lbl.parts + ['"' ~ name ~ '": "' ~ jstr(value)|trim ~ '"'] -%}
    {%- endif -%}
  {%- endfor -%}
  { {{ lbl.parts | join(', ') }} }
{%- endmacro -%}

{%- macro target_addr(ip, port) -%}
  {%- if ip.version == 6 -%}
    [{{ ip }}]:{{ port }}
  {%- else -%}
    {{ ip }}:{{ port }}
  {%- endif -%}
{%- endmacro -%}

{%- set ns = namespace(rows=[]) -%}

{#- Per-parent memo. The info labels (site/role/platform/device_type/…) come from
    the parent device/VM and repeat across every service port on that parent, so
    resolve them once. Key on the GenericForeignKey columns
    (`parent_object_type_id` / `parent_object_id`) so a cache hit doesn't even
    resolve the `service.parent` GFK. A dict gives O(1) lookup — no per-service
    linear scan over the cache (which was O(services × distinct-parents)).

    Mutation note: this relies on in-place `dict.update()` / `list.append()`,
    which NetBox's (non-immutable) SandboxedEnvironment permits. Appending in
    place avoids the O(rows²) cost of rebuilding `ns.rows` with `+ [...]`.

    NOTE: this template no longer calls get_config_context() at all — direct
    scrape needs nothing from the parent beyond its primary IP and info labels,
    so NetBox's slow ConfigContext merge is off the hot path entirely. -#}
{%- set cache = {} -%}

{%- for service in queryset -%}
  {%- set key = (service.parent_object_type_id, service.parent_object_id) -%}

  {%- if cache.get(key) is none -%}
    {#- First service seen for this parent — resolve the GFK and derive labels.
        Build the entry and stash it via update(); the dict mutation is visible
        outside this block even though a plain `{% set %}` would not be (Jinja
        scope rule), so we re-read with cache.get(key) below. -#}
    {%- set parent = service.parent -%}
    {%- set pip = parent.primary_ip if parent else None -%}
    {%- if parent and parent.status and pip -%}
      {%- set parent_info = [
        ('target_name', parent.name),
        ('site', parent.site.name if parent.site else None),
        ('dc', parent.site.slug if parent.site else None),
        ('cluster', parent.cluster.name if parent.cluster else None),
        ('tenant', parent.tenant.name if parent.tenant else None),
        ('device_role', parent.role.name if parent.role else None),
        ('platform', parent.platform.name if parent.platform else None),
        ('manufacturer', parent.device_type.manufacturer.name if parent.device_type is defined and parent.device_type and parent.device_type.manufacturer else None),
        ('device_type', parent.device_type.model if parent.device_type is defined and parent.device_type else None),
        ('location', parent.location.name if parent.location is defined and parent.location else None),
        ('rack', parent.rack.name if parent.rack is defined and parent.rack else None),
        ('description', parent.description if parent.description is defined and parent.description else None),
      ] -%}
      {%- set _ = cache.update({key: {
        'ok': true,
        'ip': pip.address.ip,
        'info': parent_info,
      }}) -%}
    {%- else -%}
      {#- Inactive / no primary_ip — cache the skip so sibling services don't re-resolve. -#}
      {%- set _ = cache.update({key: {'ok': false}}) -%}
    {%- endif -%}
  {%- endif -%}

  {%- set entry = cache.get(key) -%}
  {%- if entry.ok -%}
    {#- Per-service labels (the only things that vary between services on one parent). -#}
    {%- set svc_fields = [
      ('service_name', service.name),
      ('service_protocol', service.protocol),
      ('disable_alerts', 'true' if service.cf.get('monitoring_disable_alerts') else None),
    ] -%}

    {%- set override = service.cf.get('prometheus_scrape_url') -%}
    {%- if override -%}
      {#- Override: the CF value is used verbatim as the target. ports ignored,
          one row emitted. Decomposition (scheme/path) is the consumer's job. -#}
      {%- set _ = ns.rows.append((override, entry.info + svc_fields)) -%}
    {%- else -%}
      {#- Default: one direct-scrape row per port at the parent's primary IP. -#}
      {%- for port in service.ports -%}
        {%- set scrape_target = target_addr(entry.ip, port)|trim -%}
        {%- set _ = ns.rows.append((scrape_target, entry.info + svc_fields)) -%}
      {%- endfor -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
[
{%- for scrape_target, fields in ns.rows %}
    {
        "targets": ["{{ scrape_target }}"],
        "labels": {{ build_labels(fields) }}
    }{% if not loop.last %},{% endif %}
{%- endfor %}
]
