{#-
  Prometheus HTTP SD export template — Services.
  Bind to: ipam.service
-#}

{%- macro jstr(s) -%}
{{ s|string|replace('\\', '\\\\')|replace('"', '\\"')|replace('\n', '\\n')|replace('\r', '\\r')|replace('\t', '\\t') }}
{%- endmacro -%}

{%- macro build_labels(fields) -%}
  {%- set lbl = namespace(parts=[]) -%}
  {%- for name, value in fields -%}
    {%- if value -%}
      {%- set lbl.parts = lbl.parts + ['"' ~ name ~ '": "' ~ jstr(value)|trim ~ '"'] -%}
    {%- endif -%}
  {%- endfor -%}
  { {{ lbl.parts | join(', ') }} }
{%- endmacro -%}

{%- macro target_addr(ip, port) -%}
  {%- if ip.version == 6 -%}
    [{{ ip }}]:{{ port }}
  {%- else -%}
    {{ ip }}:{{ port }}
  {%- endif -%}
{%- endmacro -%}

{%- macro param_value(v) -%}
{%- if v is none or v == '' -%}
{%- elif v is string -%}
{{ v }}
{%- elif v is iterable -%}
{{ v | select | map('string') | join(',') }}
{%- else -%}
{{ v }}
{%- endif -%}
{%- endmacro -%}

{%- set ns = namespace(rows=[]) -%}
{%- for service in queryset -%}
  {%- set parent = service.device or service.virtual_machine -%}
  {%- if parent and parent.status -%}
    {%- set data = parent.get_config_context() -%}
    {%- set prom = data.get('prometheus-export-template', {}) -%}
    {%- set prom_oob = data.get('prometheus-export-template-oob') -%}

    {#- Shared info labels — identical across all emissions and ports of this service. -#}
    {%- set info_fields = [
      ('target_name', parent.name),
      ('service_name', service.name),
      ('service_protocol', service.protocol),
      ('site', parent.site.name if parent.site else None),
      ('dc', parent.site.slug if parent.site else None),
      ('cluster', parent.cluster.name if parent.cluster else None),
      ('tenant', parent.tenant.name if parent.tenant else None),
      ('device_role', parent.role.name if parent.role else None),
      ('platform', parent.platform.name if parent.platform else None),
      ('manufacturer', parent.device_type.manufacturer.name if parent.device_type is defined and parent.device_type and parent.device_type.manufacturer else None),
      ('device_type', parent.device_type.model if parent.device_type is defined and parent.device_type else None),
      ('location', parent.location.name if parent.location is defined and parent.location else None),
      ('rack', parent.rack.name if parent.rack is defined and parent.rack else None),
      ('description', parent.description if parent.description is defined and parent.description else None),
    ] -%}

    {#- Build the list of (ip_obj, cfg, is_primary) emissions for this service's parent.
        Primary: emit if parent has primary_ip (legacy behaviour — no `port` requirement
                 since the service contributes its own ports).
        OOB:     emit if `prometheus-export-template-oob` context is set on the parent
                 and parent has `oob_ip`. VMs lack `oob_ip` — `is defined` guard skips
                 them. -#}
    {%- set emissions = namespace(items=[]) -%}
    {%- if parent.primary_ip -%}
      {%- set emissions.items = emissions.items + [(parent.primary_ip, prom, true)] -%}
    {%- endif -%}
    {%- if parent.oob_ip is defined and parent.oob_ip and prom_oob -%}
      {%- set emissions.items = emissions.items + [(parent.oob_ip, prom_oob, false)] -%}
    {%- endif -%}

    {%- for source_ip_obj, cfg, is_primary in emissions.items -%}
      {%- set exporter = cfg.get('exporter') -%}
      {#- Scheme: prefixes __param_target when exporter routing is in use, emitted as
          __scheme__ otherwise. `target_scheme` is kept as a legacy alias for `scheme`. -#}
      {%- set scheme = cfg.get('scheme') or cfg.get('target_scheme') -%}

      {#- Scrape interval / timeout — CFs only on primary. -#}
      {%- if is_primary and parent.cf is defined -%}
        {%- set scrape_interval = parent.cf.get('prometheus_exporter_scrape_interval') or cfg.get('scrape_interval') -%}
        {%- set scrape_timeout = parent.cf.get('prometheus_exporter_scrape_timeout') or cfg.get('scrape_timeout') -%}
      {%- else -%}
        {%- set scrape_interval = cfg.get('scrape_interval') -%}
        {%- set scrape_timeout = cfg.get('scrape_timeout') -%}
      {%- endif -%}

      {#- Params — CFs only on primary. -#}
      {%- set params_ns = namespace(parts=[]) -%}
      {%- set ctx_params = cfg.get('params') or {} -%}
      {%- for k, v in ctx_params.items() -%}
        {%- if is_primary and parent.cf is defined -%}
          {%- set cf_value = parent.cf.get('prometheus_exporter_' ~ k) -%}
          {%- set raw = cf_value if cf_value else v -%}
        {%- else -%}
          {%- set raw = v -%}
        {%- endif -%}
        {%- set final = param_value(raw)|trim -%}
        {%- set params_ns.parts = params_ns.parts + [('__param_' ~ k, final)] -%}
      {%- endfor -%}
      {%- if is_primary and parent.cf is defined -%}
        {#- Keys handled out-of-band (not __param_*) are excluded from this sweep. -#}
        {%- set reserved_cf_keys = ['scrape_interval', 'scrape_timeout'] -%}
        {%- set seen_keys = (ctx_params.keys() | list) + reserved_cf_keys -%}
        {%- for cf_name, cf_value in parent.cf.items() -%}
          {%- if cf_name.startswith('prometheus_exporter_') and cf_value -%}
            {%- set param_key = cf_name[20:] -%}
            {%- if param_key not in seen_keys -%}
              {%- set final = param_value(cf_value)|trim -%}
              {%- set params_ns.parts = params_ns.parts + [('__param_' ~ param_key, final)] -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- set per_emission_fields = [
        ('__metrics_path__', cfg.get('metrics_path')),
        ('__scrape_interval__', scrape_interval),
        ('__scrape_timeout__', scrape_timeout),
        ('exporter_type', cfg.get('exporter_type')),
      ] -%}

      {%- for port in service.ports -%}
        {%- set probe_addr = target_addr(source_ip_obj.address.ip, port)|trim -%}
        {%- if exporter -%}
          {%- set scrape_target = exporter -%}
          {%- if scheme -%}
            {%- set param_target = scheme ~ '://' ~ probe_addr -%}
          {%- else -%}
            {%- set param_target = probe_addr -%}
          {%- endif -%}
          {%- set scheme_label = None -%}
        {%- else -%}
          {%- set scrape_target = probe_addr -%}
          {%- set param_target = None -%}
          {%- set scheme_label = scheme -%}
        {%- endif -%}
        {%- set row_fields = [
          ('__param_target', param_target),
          ('__scheme__', scheme_label),
        ] + per_emission_fields + params_ns.parts + info_fields -%}
        {%- set ns.rows = ns.rows + [(scrape_target, row_fields)] -%}
      {%- endfor -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}
[
{%- for scrape_target, fields in ns.rows %}
    {
        "targets": ["{{ scrape_target }}"],
        "labels": {{ build_labels(fields) }}
    }{% if not loop.last %},{% endif %}
{%- endfor %}
]
